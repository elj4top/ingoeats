# Copy this file to .env and fill in real values. .env itself must stay out of git.

# --- Postgres ---
POSTGRES_USER=ingoeats
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ingoeats

# Built from the three values above - host must match the service name in docker-compose.yml
DATABASE_URL=postgresql://ingoeats:change-me@ingoeats_postgres:5432/ingoeats

# --- JWT ---
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://ingoeats_redis:6379/0
CELERY_RESULT_BACKEND=redis://ingoeats_redis:6379/0

# --- Business rules (must match field names in app/core/config.py) ---
DELIVERY_FEE=150.0
PLATFORM_COMMISSION_RATE=0.10
RIDER_DELIVERY_SHARE=0.90

# --- Paystack ---
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
